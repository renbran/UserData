<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Commission Module Category -->
        <!--        <record model="res.groups.privilege" id="module_category_commission">-->
        <record model="ir.module.category" id="module_category_commission">
            <field name="name">Sales Commission</field>
            <field name="description">User access levels for the Sales Commission module.</field>
            <field name="sequence">20</field>
        </record>

        <!-- Commission User Group -->
        <record id="group_commission_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_commission"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">The user will be able to see their own commission records.</field>
        </record>

        <!-- Commission Manager Group -->
        <record id="group_commission_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_commission"/>
            <field name="implied_ids" eval="[(4, ref('group_commission_user'))]"/>
            <field name="comment">The user will be able to manage commission configurations and view all commission
                records.
            </field>
        </record>

        <!-- Commission Administrator Group -->
        <record id="group_commission_admin" model="res.groups">
            <field name="name">Administrator</field>
            <field name="category_id" ref="module_category_commission"/>
            <field name="implied_ids" eval="[(4, ref('group_commission_manager'))]"/>
            <field name="comment">The user will have full access to all commission features.</field>
        </record>

        <!-- Record Rules -->

        <!-- Commission Record Rules -->
        <record id="commission_record_user_rule" model="ir.rule">
            <field name="name">Commission Record: User can see own records</field>
            <field name="model_id" ref="model_commission_record"/>
            <field name="groups" eval="[(4, ref('group_commission_user'))]"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
        </record>

        <record id="commission_record_manager_rule" model="ir.rule">
            <field name="name">Commission Record: Manager can see all records</field>
            <field name="model_id" ref="model_commission_record"/>
            <field name="groups" eval="[(4, ref('group_commission_manager'))]"/>
            <field name="domain_force">[]</field>
        </record>

        <!-- Commission Configuration Rules -->
        <record id="commission_config_user_rule" model="ir.rule">
            <field name="name">Commission Config: User can read</field>
            <field name="model_id" ref="model_commission_config"/>
            <field name="groups" eval="[(4, ref('group_commission_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="commission_config_manager_rule" model="ir.rule">
            <field name="name">Commission Config: Manager can manage</field>
            <field name="model_id" ref="model_commission_config"/>
            <field name="groups" eval="[(4, ref('group_commission_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>


