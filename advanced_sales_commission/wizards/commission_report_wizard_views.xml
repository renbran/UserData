<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Commission Report Wizard Form View -->
        <record id="commission_report_wizard_view_form" model="ir.ui.view">
            <field name="name">commission.report.wizard.form</field>
            <field name="model">commission.report.wizard</field>
            <field name="arch" type="xml">
                <form string="Commission Report">
                    <group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="report_type"/>
                        </group>
                        <group>
                            <field name="user_ids" widget="many2many_tags"/>
                            <field name="group_by"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_generate_report" type="object" string="Generate Report" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Action for Commission Report Wizard -->
        <record id="action_commission_report_wizard" model="ir.actions.act_window">
            <field name="name">Commission Report</field>
            <field name="res_model">commission.report.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <!-- Date Range Report Wizard Form View -->
        <record id="commission_date_range_report_view_form" model="ir.ui.view">
            <field name="name">commission.date.range.report.form</field>
            <field name="model">commission.date.range.report</field>
            <field name="arch" type="xml">
                <form string="Commission Date Range Report">
                    <group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="group_by"/>
                        </group>
                        <group>
                            <field name="include_draft"/>
                            <field name="include_cancelled"/>
                        </group>
                    </group>
                    <group string="Filters">
                        <field name="user_ids" widget="many2many_tags"/>
                        <field name="partner_ids" widget="many2many_tags"/>
                        <field name="product_ids" widget="many2many_tags"/>
                        <field name="category_ids" widget="many2many_tags"/>
                    </group>
                    <footer>
                        <button name="action_generate_report" type="object" string="Generate Report" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Action for Date Range Report -->
        <record id="action_commission_date_range_report" model="ir.actions.act_window">
            <field name="name">Commission Date Range Report</field>
            <field name="res_model">commission.date.range.report</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <!-- Date Range Report Line list View -->
        <record id="commission_date_range_report_line_view_list" model="ir.ui.view">
            <field name="name">commission.date.range.report.line.list</field>
            <field name="model">commission.date.range.report.line</field>
            <field name="arch" type="xml">
                <tree string="Commission Date Range Report">
                    <field name="name"/>
                    <field name="total_sales" sum="Total Sales"/>
                    <field name="total_commission" sum="Total Commission"/>
                    <field name="manager_commission" sum="Manager Commission"/>
                    <field name="director_commission" sum="Director Commission"/>
                    <field name="commission_count" sum="Commission Count"/>
                    <field name="avg_commission_rate"/>
                </tree>
            </field>
        </record>
    </data>
</odoo>

