<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Automated Commission Calculation Cron Job -->
        <record id="ir_cron_commission_calculation" model="ir.cron">
            <field name="name">Automated Commission Calculation</field>
            <field name="model_id" ref="advanced_sales_commission.model_commission_record"/>
            <field name="state">code</field>
            <field name="code">model.cron_calculate_commissions()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
<!--            <field name="numbercall">-1</field>-->
            <field name="active" eval="True"/>
            <field name="user_id" ref="base.user_root"/>
        </record>


        <!-- Monthly Commission Period Creation -->
        <record id="ir_cron_commission_period_creation" model="ir.cron">
            <field name="name">Monthly Commission Period Creation</field>
            <field name="model_id" ref="advanced_sales_commission.model_commission_period"/>
            <field name="state">code</field>
            <field name="code">model.cron_create_next_period()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">months</field>
<!--            <field name="numbercall">-1</field>-->
            <field name="active" eval="True"/>
            <field name="user_id" ref="base.user_root"/>
        </record>


        <!-- Commission Invoice Status Update -->
        <record id="ir_cron_commission_invoice_status" model="ir.cron">
            <field name="name">Commission Invoice Status Update</field>
            <field name="model_id" ref="advanced_sales_commission.model_commission_record"/>
            <field name="state">code</field>
            <field name="code">model.cron_update_invoice_status()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
<!--            <field name="numbercall">-1</field>-->
            <field name="active" eval="True"/>
            <field name="user_id" ref="base.user_root"/>
        </record>

    </data>
</odoo>

