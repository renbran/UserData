<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Demo Commission Configuration -->
        <record id="commission_config_demo" model="commission.config">
            <field name="name">Demo Commission Configuration</field>
            <field name="commission_type">hybrid</field>
            <field name="calculation_method">percentage</field>
            <field name="default_rate">4.0</field>
            <field name="auto_calculate" eval="True"/>
            <field name="auto_invoice" eval="False"/>
            <field name="sequence">100</field>
            <field name="active" eval="True"/>
        </record>

        <!-- Demo Commission Rules -->
        <record id="commission_rule_demo_high_value" model="commission.rule">
            <field name="name">Demo High Value Rule (>$5,000)</field>
            <field name="config_id" ref="commission_config_demo"/>
            <field name="condition_type">amount</field>
            <field name="commission_type">percentage</field>
            <field name="commission_rate">6.0</field>
            <field name="min_amount">5000.0</field>
            <field name="sequence">5</field>
            <field name="active" eval="True"/>
        </record>

        <record id="commission_rule_demo_standard" model="commission.rule">
            <field name="name">Demo Standard Rule</field>
            <field name="config_id" ref="commission_config_demo"/>
            <field name="condition_type">always</field>
            <field name="commission_type">percentage</field>
            <field name="commission_rate">4.0</field>
            <field name="sequence">10</field>
            <field name="active" eval="True"/>
        </record>

        <!-- Demo Commission Assignment -->
        <record id="commission_assignment_demo" model="commission.assignment">
            <field name="user_id" ref="base.user_demo"/>
            <field name="config_id" ref="commission_config_demo"/>
            <field name="date_from" eval="(DateTime.now() - timedelta(days=30)).strftime('%Y-%m-%d')"/>
            <field name="manager_rate">1.0</field>
            <field name="active" eval="True"/>
        </record>

        <!-- Demo Commission Period -->
        <record id="commission_period_demo" model="commission.period">
            <field name="name">Demo Period - Current Month</field>
            <field name="code">DEMO-CURRENT</field>
            <field name="date_from" eval="DateTime.now().replace(day=1).strftime('%Y-%m-%d')"/>
            <field name="date_to" eval="(DateTime.now().replace(day=1) + timedelta(days=32)).replace(day=1) - timedelta(days=1)"/>
            <field name="period_type">monthly</field>
            <field name="state">open</field>
        </record>

        <!-- Demo Partner with Commission Settings -->
        <record id="partner_demo_commission" model="res.partner">
            <field name="name">Demo Commission Customer</field>
            <field name="is_company" eval="True"/>
            <field name="is_commission_partner" eval="True"/>
            <field name="commission_category">premium</field>
            <field name="commission_rate_override">5.5</field>
        </record>

    </data>
</odoo>

